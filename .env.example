# ============================================================================
# Wearurway — environment variables
# Copy this file to .env (for local) or paste these keys into your hosting
# provider's variables panel (Railway → Variables, etc).
# ============================================================================

# ---- Server runtime ----
NODE_ENV=production
# PORT is provided automatically by most hosts (Railway, Render, etc).
# Only set this manually for local development.
# PORT=8080

# ---- Database (Supabase Postgres or any PostgreSQL) ----
# Use the connection-pooler URL for Supabase (port 6543).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# ---- Cloudflare R2 (object storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional public URL of the bucket (used for direct image URLs).
R2_PUBLIC_URL=

# ---- Admin panel ----
# Password used to log in at /admin
ADMIN_PASSWORD=

# ---- OpenAI (used for AI background-removal in the designer) ----
# Get a key from https://platform.openai.com/
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Optional ----
# LOG_LEVEL=info
